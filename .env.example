# Root compose defaults (safe for local self-host / dev)
# Copy to .env to override.

# --- app ports (host) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --- redis ---
# Redis port on host (use non-default 6380 to avoid conflicts)
REDIS_PORT=6380

# --- database ---
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- backend settings (see backend/.env.example for full list) ---
# CORS origins - comma-separated list of allowed frontend origins
# For production: include both HTTP (IP access) and HTTPS (domain) origins
# Example: CORS_ORIGINS=http://192.168.1.100:3000,https://mc.example.com
CORS_ORIGINS=http://localhost:3000
DB_AUTO_MIGRATE=true
LOG_LEVEL=INFO
REQUEST_LOG_SLOW_MS=1000
AUTH_MODE=local
# REQUIRED when AUTH_MODE=local (must be non-placeholder and at least 50 chars).
LOCAL_AUTH_TOKEN=

# --- frontend settings ---
# Public URL used by the browser to reach the API.
# For production: set explicitly to your HTTPS domain (e.g., https://mc.example.com)
# Use `auto` only for local dev (targets same host on port 8000)
# NOTE: `auto` mode may incorrectly append port in some cases - prefer explicit URL for production
NEXT_PUBLIC_API_URL=auto
NEXT_PUBLIC_AUTH_MODE=local
